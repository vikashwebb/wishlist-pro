{% liquid
  assign customer_id = ''
  if customer
    assign customer_id = customer.id
  endif
%}

{% unless product %}
  {% comment %}Product page embed only renders when a product is available.{% endcomment %}
{% else %}
<div
  data-wishlist-pdp
  data-wishlist-auto-insert="true"
  class="wishlist-pro-inline wishlist-pro-inline--pending"
  data-wishlist-config='{
    "productId": {{ product.admin_graphql_api_id | json }},
    "productHandle": {{ product.handle | json }},
    "customerId": {{ customer_id | json }},
    "configUrl": {{ "/apps/wishlist-proxy/wishlist/config" | json }},
    "statusUrl": {{ "/apps/wishlist-proxy/wishlist/status" | json }},
    "syncUrl": {{ "/apps/wishlist-proxy/wishlist/sync" | json }},
    "toggleUrl": {{ "/apps/wishlist-proxy/wishlist/toggle" | json }},
    "loginUrl": {{ routes.account_login_url | json }},
    "addLabel": {{ block.settings.add_label | json }},
    "addedLabel": {{ block.settings.added_label | json }},
    "loginText": {{ block.settings.login_text | json }},
    "targetSelector": {{ block.settings.target_selector | json }},
    "buttonStyle": {{ block.settings.button_style | json }},
    "buttonAccentColor": {{ block.settings.button_accent_color | json }},
    "buttonTextColor": {{ block.settings.button_text_color | json }},
    "buttonIconColor": {{ block.settings.button_icon_color | json }}
  }'
>
  <button
    type="button"
    class="wishlist-pro-button"
    data-wishlist-button
    aria-pressed="false"
  >
    <span class="wishlist-pro-button__icon" aria-hidden="true">♥</span>
    <span data-wishlist-label>{{ block.settings.add_label }}</span>
  </button>
</div>
{% endunless %}

{% schema %}
{
  "name": "Product page button",
  "target": "body",
  "stylesheet": "wishlist.css",
  "javascript": "wishlist-pdp.js",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "add_label",
      "label": "Add label",
      "default": "Add to Wishlist"
    },
    {
      "type": "text",
      "id": "added_label",
      "label": "Added label",
      "default": "Added to Wishlist"
    },
    {
      "type": "text",
      "id": "login_text",
      "label": "Logged out helper text",
      "default": "Sign in to save this product."
    },
    {
      "type": "text",
      "id": "target_selector",
      "label": "Optional custom target selector",
      "info": "Use this if your theme needs a custom product-page anchor.",
      "default": ".product-form, product-form, .product__info-wrapper, .product-info"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "outline",
      "options": [
        { "value": "outline", "label": "Outline" },
        { "value": "solid", "label": "Solid" },
        { "value": "icon-only", "label": "Icon only" }
      ]
    },
    {
      "type": "color",
      "id": "button_accent_color",
      "label": "Accent color",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_icon_color",
      "label": "Icon color",
      "default": "#0f172a"
    }
  ]
}
{% endschema %}
